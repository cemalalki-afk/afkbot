MainFrame.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
MainFrame.BorderSizePixel = 2
MainFrame.BorderColor3 = Color3.fromRGB(0, 255, 0)
MainFrame.Active = true
MainFrame.Draggable = true -- Paneli istediğin yere çekebilirsin

local Title = Instance.new("TextLabel", MainFrame)
Title.Size = UDim2.new(1, 0, 0, 35)
Title.Text = "RISEHUB V1.5"
Title.TextColor3 = Color3.fromRGB(0, 255, 0)
Title.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
Title.Font = Enum.Font.Code

-- Buton Oluşturucu Fonksiyon
local function CreateButton(text, pos, callback)
    local btn = Instance.new("TextButton", MainFrame)
    btn.Size = UDim2.new(0.8, 0, 0, 30)
    btn.Position = UDim2.new(0.1, 0, 0, pos)
    btn.Text = text
    btn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.Font = Enum.Font.SourceSans
    btn.BorderSizePixel = 0
    
    btn.MouseButton1Click:Connect(function()
        callback(btn)
    end)
    return btn
end

-- Butonlar
local aimBtn = CreateButton("Aimbot: ON", 50, function(b)
    RiseSettings.Aimbot = not RiseSettings.Aimbot
    b.Text = RiseSettings.Aimbot and "Aimbot: ON" or "Aimbot: OFF"
    b.TextColor3 = RiseSettings.Aimbot and Color3.fromRGB(0, 255, 0) or Color3.fromRGB(255, 0, 0)
end)

local espBtn = CreateButton("ESP: ON", 90, function(b)

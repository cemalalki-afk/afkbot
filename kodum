    b.Text = RiseSettings.ESP and "ESP: ON" or "ESP: OFF"
    b.TextColor3 = RiseSettings.ESP and Color3.fromRGB(0, 255, 0) or Color3.fromRGB(255, 0, 0)
end)

local teamBtn = CreateButton("TeamCheck: ON", 130, function(b)
    RiseSettings.TeamCheck = not RiseSettings.TeamCheck
    b.Text = RiseSettings.TeamCheck and "TeamCheck: ON" or "TeamCheck: OFF"
end)

local closeLabel = Instance.new("TextLabel", MainFrame)
closeLabel.Size = UDim2.new(1, 0, 0, 20)
closeLabel.Position = UDim2.new(0, 0, 1, -25)
closeLabel.Text = "Press [INSERT] to Hide"
closeLabel.TextColor3 = Color3.fromRGB(150, 150, 150)
closeLabel.BackgroundTransparency = 1
closeLabel.TextSize = 12

-- [[ FONKSİYONLAR ]]
local function GetTarget()
    local closest = nil
    local maxDist = math.huge
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= LocalPlayer and v.Character and v.Character:FindFirstChild("Head") then
            if RiseSettings.TeamCheck and v.Team == LocalPlayer.Team then continue end
            local pos, vis = Camera:WorldToViewportPoint(v.Character.Head.Position)
            if vis then
                local mag = (Vector2.new(pos.X, pos.Y) - UIS:GetMouseLocation()).Magnitude
                if mag < maxDist then
                    maxDist = mag
                    closest = v
                end
            end
        end
    end
    return closest
end

RunService.RenderStepped:Connect(function()
    -- Aimbot Logic
    if RiseSettings.Aimbot and UIS:IsKeyDown(RiseSettings.AimKey) then
        local target = GetTarget()
        if target then
            Camera.CFrame = Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position, target.Character.Head.Position), RiseSettings.Smoothness)
        end
    end
    
    -- ESP Logic (Basit Highlight)
    for _, v in pairs(Players:GetPlayers()) do
        if v.Character then
            local hl = v.Character:FindFirstChild("RiseESP")
            if RiseSettings.ESP and v ~= LocalPlayer then
                if not hl then
                    hl = Instance.new("Highlight", v.Character)
                    hl.Name = "RiseESP"
                end
                hl.FillColor = (RiseSettings.TeamCheck and v.Team == LocalPlayer.Team) and Color3.fromRGB(0, 0, 255) or Color3.fromRGB(0, 255, 0)
                hl.FillTransparency = 0.6
            else
                if hl then hl:Destroy() end
            end
        end
    end
end)

-- Menü Gizleme
UIS.InputBegan:Connect(function(input)
    if input.KeyCode == Enum.KeyCode.Insert then
        MainFrame.Visible = not MainFrame.Visible
    end
end)

print("RiseHub V1.5 Loaded Successfully.")
